# Database (SQLite 기본값 - PostgreSQL 없이 바로 실행 가능)
DATABASE_URL=sqlite+aiosqlite:///./meta_commander.db
# PostgreSQL 사용 시: DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/meta_commander

# Meta API
META_APP_ID=your_app_id
META_APP_SECRET=your_app_secret
META_ACCESS_TOKEN=your_access_token

# AI Services
ANTHROPIC_API_KEY=your_anthropic_key
OPENAI_API_KEY=your_openai_key
REPLICATE_API_TOKEN=your_replicate_token

# Chroma Vector DB (로컬 실행, 설정 변경 불필요)
CHROMA_PERSIST_DIRECTORY=./chroma_data

# JWT
JWT_SECRET_KEY=your_secret_key
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# Server
DEBUG=true
CORS_ORIGINS=http://localhost:3000
