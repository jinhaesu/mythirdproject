# Database (Railway provides DATABASE_URL automatically with PostgreSQL add-on)
# Local: sqlite+aiosqlite:///./meta_commander.db
# Production: postgresql+asyncpg://user:password@host:5432/meta_commander
DATABASE_URL=sqlite+aiosqlite:///./meta_commander.db

# AI Services (Required)
ANTHROPIC_API_KEY=sk-ant-your-key-here
OPENAI_API_KEY=sk-your-key-here
REPLICATE_API_TOKEN=your-token-here

# Meta API (Optional - users connect via UI)
META_APP_ID=
META_APP_SECRET=
META_ACCESS_TOKEN=
META_API_VERSION=v19.0

# JWT Authentication (MUST change in production!)
JWT_SECRET_KEY=change-this-to-a-strong-random-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS (Set to your Vercel frontend URL in production)
CORS_ORIGINS=http://localhost:3000

# Server
PORT=8000
DEBUG=false
